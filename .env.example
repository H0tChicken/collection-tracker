# --- Database (PostgreSQL) ---
# Local dev (Postgres running on host or via docker compose):
DATABASE_URL="postgresql://cardtracker:cardtracker@localhost:5432/cardtracker?schema=public"

# --- Storage ---
# Directory where uploaded card images are written (mounted volume in Docker).
UPLOAD_DIR="./data/uploads"

# Max upload size in megabytes.
MAX_UPLOAD_MB="15"

# --- App ---
NODE_ENV="development"
# Public base URL (used for absolute links / image URLs if needed).
APP_URL="http://localhost:3000"

# --- Auth (v1: disabled; app runs behind Traefik + Authentik forward-auth) ---
# When "true", the app will trust the configured forwarded identity header.
AUTH_TRUST_PROXY_HEADERS="false"
# Header Authentik/your proxy sets with the authenticated username.
AUTH_PROXY_USER_HEADER="X-authentik-username"
